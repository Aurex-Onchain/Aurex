# OKX
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PROJECT_ID=

# Data Providers
# ALCHEMY_API_KEY=
# BIRDEYE_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
