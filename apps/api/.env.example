# Aurex API Environment
AUREX_ENV=development

# Database (not required for MVP)
# DATABASE_URL=postgresql://localhost:5432/aurex

# Redis (not required for MVP)
# REDIS_URL=redis://localhost:6379

# AI
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

