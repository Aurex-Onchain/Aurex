# X Layer / Advisor
AUREX_POOL_IDS=

# Signing backend:
# - private-key: local env key with viem (existing behavior)
# - onchainos: OKX OnchainOS Agentic Wallet, with TEE-backed signing
AUREX_SIGNER_PROVIDER=private-key

# Local private-key signer (do not commit real keys)
AUREX_PRIVATE_KEY=

# OnchainOS Agentic Wallet signer
# Install and log in first:
#   curl -sSL https://raw.githubusercontent.com/okx/onchainos-skills/main/install.sh | sh
#   onchainos wallet login
AUREX_ONCHAINOS_ADDRESS=
AUREX_ONCHAINOS_CHAIN=196
ONCHAINOS_CLI=onchainos

# Keep false unless the operator has explicitly accepted OnchainOS confirmation prompts.
AUREX_ONCHAINOS_AUTO_CONFIRM=false

# Security scan is enabled by default before OnchainOS contract-call.
# Set only for local testing if OKX security scan is unavailable.
AUREX_ONCHAINOS_ALLOW_UNSCANNED=false
AUREX_ONCHAINOS_DISABLE_SECURITY_SCAN=false

# OpenClaw Gateway (Optional - for advanced AI chat in Web UI)
# The Web UI chat works without this, but OpenClaw enables full AI conversations.
# To enable:
#   1. Install: npm install -g openclaw
#   2. Start gateway: openclaw gateway start
#   3. Get token: openclaw gateway token
#   4. Set OPENCLAW_GATEWAY_TOKEN below and restart Advisor
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=main
